# Meta app credentials (from developers.facebook.com → your app → Settings → Basic)
META_APP_ID=
META_APP_SECRET=

# Filled in by `npm run setup-token` (or set manually)
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# Required by refresh-token.js to update the IG_ACCESS_TOKEN repo secret.
# Must be a PAT (classic: `repo`; fine-grained: Actions read + Secrets read/write).
# Not needed locally unless you're testing refresh-token.js.
GH_TOKEN=
# owner/name — auto-populated inside GitHub Actions
GITHUB_REPOSITORY=

# AI content generation
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
